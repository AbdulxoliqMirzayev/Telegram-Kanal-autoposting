TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_id
TELEGRAM_CHANNEL_IDS=@your_channel_id,@your_second_channel,@your_third_channel

# Optional if USE_TELETHON=false. Required only for private/session-based Telegram scraping.
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+998XXXXXXXXX
USE_TELETHON=false

# Optional, but recommended for better Uzbek financial translation.
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini

# Bot/admin settings
TIMEZONE=Asia/Tashkent
ADMIN_USER_IDS=123456789

# Local paths. On Railway, set DATA_DIR=/app/data and DB_PATH=/app/data/posted_news.sqlite3.
DATA_DIR=data
DB_PATH=data/posted_news.sqlite3
TELETHON_SESSION_PATH=data/session.session
HTTP_TIMEOUT=20

# 8 posts/day. Format: HH:MM:source where source is web or telegram.
POST_SCHEDULE=08:08:web,10:10:telegram,12:12:telegram,13:13:web,15:15:web,17:17:telegram,19:19:web,21:21:telegram

# Telegram source channels: public usernames, @usernames, or https://t.me/user links.
TELEGRAM_SOURCE_CHANNELS=https://t.me/investfuture,https://t.me/multievan,https://t.me/bankrollo,https://t.me/prostoecon,https://t.me/ecotopor,https://t.me/ImpossibleAnnouncements

# Web sources: TradingView, Webull, Yahoo Finance, Investing.com RSS.
WEB_SOURCE_URLS=https://www.tradingview.com/news/,https://www.webullapp.com/news,https://finance.yahoo.com/news/rssindex,https://www.investing.com/rss/news_25.rss,https://www.investing.com/rss/news_95.rss,https://www.investing.com/rss/news_14.rss
